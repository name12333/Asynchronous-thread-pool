*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.a
*.lib

# Executables
*.exe
*.out
*.app

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Logs
*.log

# OS specific
.DS_Store
Thumbs.db
